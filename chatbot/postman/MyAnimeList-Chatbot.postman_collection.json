{
  "info": {
    "_postman_id": "2f6b8a5f-4f2d-4b1d-a145-8d11c8d9e931",
    "name": "MyAnimeList Chatbot API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection para testar a API Flask do chatbot com crawler + TF-IDF."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:5000"
    }
  ],
  "item": [
    {
      "name": "1) Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Verifica se a API está no ar."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "pm.test('Health status is ok', function () {",
              "    pm.expect(jsonData.status).to.eql('ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2) Crawl and Index",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"urls\": [\n    \"https://myanimelist.net/topanime.php?type=bypopularity\",\n    \"https://myanimelist.net/anime/season\",\n    \"https://myanimelist.net/topanime.php?type=upcoming\"\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/crawl",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "crawl"
          ]
        },
        "description": "Executa scraping das URLs e recria o índice TF-IDF."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "pm.test('documents_indexed exists', function () {",
              "    pm.expect(jsonData.documents_indexed).to.be.a('number');",
              "});",
              "",
              "pm.environment.set('documentsIndexed', jsonData.documents_indexed);"
            ]
          }
        }
      ]
    },
    {
      "name": "3) Ask",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"question\": \"Quais animes aparecem entre os mais populares e os da temporada atual?\",\n  \"top_k\": 3\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/ask",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "ask"
          ]
        },
        "description": "Pergunta ao chatbot com base no índice criado em /crawl."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const jsonData = pm.response.json();",
              "pm.test('answer exists', function () {",
              "    pm.expect(jsonData.answer).to.be.a('string');",
              "});",
              "",
              "pm.test('results is array', function () {",
              "    pm.expect(jsonData.results).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
